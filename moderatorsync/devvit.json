{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "moderatorsync",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "dashboard": {
        "entry": "dashboard.html"
      },
      "game": {
        "entry": "game.html"
      },
      "dossier-game": {
        "entry": "dossier-game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Create a new post",
        "description": "moderatorsync",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Example form",
        "description": "Show a simple form",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/example-form"
      },
      {
        "label": "ModSync Dossier",
        "description": "View user context and team notes",
        "location": [
          "post",
          "comment"
        ],
        "forUserType": "moderator",
        "endpoint": "/internal/menu/dossier-open"
      }
      ,
      {
        "label": "ModSync Dashboard",
        "description": "Open ModSync admin dashboard",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/dashboard-open"
      },
      {
        "label": "ModSync Demo",
        "description": "Open seeded demo mode",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/demo-open"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onCommentSubmit": "/internal/triggers/on-comment-submit"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "moderatorsync_dev"
  }
}