{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "moderatorsync",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      },
      "dossier-game": {
        "entry": "dossier-game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "ModSync Dossier",
        "description": "View user context and team notes",
        "location": [
          "post",
          "comment"
        ],
        "forUserType": "moderator",
        "endpoint": "/internal/menu/dossier-open"
      },
      {
        "label": "Create ModSync Post",
        "description": "Create the ModSync dashboard post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Seed Demo Data",
        "description": "Load sample users for testing",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/demo-seed"
      },
      {
        "label": "View Demo: Spammer",
        "description": "View SpammyMcSpamface dossier",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/demo-view-spammer"
      },
      {
        "label": "View Demo: Trusted",
        "description": "View HelpfulContributor dossier",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/demo-view-trusted"
      },
      {
        "label": "View Demo: Watchlist",
        "description": "View SuspiciousNewbie dossier",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/demo-view-watchlist"
      }
    ]
  },
  "forms": {
    "exampleForm": "/internal/form/example-submit"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onCommentSubmit": "/internal/triggers/on-comment-submit"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "moderatorsync_dev"
  }
}
